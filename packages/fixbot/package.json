{
	"name": "@fixbot/pi-fixbot",
	"version": "0.1.0",
	"type": "module",
	"description": "Self-hosted coding agent daemon for GitHub repositories",
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"private": true,
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts"
		},
		"./*": {
			"types": "./src/*.ts",
			"import": "./src/*.ts"
		},
		"./commands/*": {
			"types": "./src/commands/*.ts",
			"import": "./src/commands/*.ts"
		}
	},
	"dependencies": {
		"@fixbot/pi-ai": "workspace:*",
		"@fixbot/pi-coding-agent": "workspace:*",
		"@fixbot/pi-utils": "workspace:*"
	},
	"scripts": {
		"test": "bun test"
	}
}
