{
	"name": "@fixbot/pi-fixbot",
	"version": "0.1.0",
	"type": "module",
	"description": "Self-hosted coding agent daemon for GitHub repositories",
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"private": true,
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts"
		},
		"./*": {
			"types": "./src/*.ts",
			"import": "./src/*.ts"
		},
		"./commands/*": {
			"types": "./src/commands/*.ts",
			"import": "./src/commands/*.ts"
		}
	},
	"dependencies": {
		"@oh-my-pi/pi-ai": "workspace:*",
		"@oh-my-pi/pi-coding-agent": "workspace:*",
		"@oh-my-pi/pi-utils": "workspace:*",
		"chalk": "^5.6",
		"yaml": "^2.4.0"
	},
	"scripts": {
		"test": "bun test"
	}
}
